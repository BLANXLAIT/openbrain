# Required secrets — set via: supabase secrets set KEY=value
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are automatic in Edge Functions.

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Slack bot token (starts with xoxb-)
SLACK_BOT_TOKEN=

# Slack capture channel ID (starts with C)
SLACK_CAPTURE_CHANNEL=

# MCP server access key (generate with: openssl rand -hex 32)
MCP_ACCESS_KEY=
